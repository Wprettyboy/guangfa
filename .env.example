DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-with-your-key
# 云端模型/Embedding 出站代理。仅支持 HTTP(S)，项目变量优先于 HTTPS_PROXY、HTTP_PROXY、ALL_PROXY。
# 本机代理示例：http://127.0.0.1:7890
AI_PROXY_URL=
LOCAL_LLM_BASE_URL=http://127.0.0.1:8129/v1
LOCAL_LLM_MODEL=qwen3.6-35b-a3b
LOCAL_LLM_API_KEY=
ONLYOFFICE_AI_CLIENT_API_KEY=sk-local
EMBEDDING_BASE_URL=http://127.0.0.1:8000/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_MS=30000
ONLYOFFICE_JWT_SECRET=replace-with-at-least-32-random-characters
ONLYOFFICE_SERVER_URL=http://127.0.0.1:8080
ONLYOFFICE_PUBLIC_URL=http://127.0.0.1:8080
OFFICE_PUBLIC_BASE_URL=http://host.docker.internal:5173
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=60000

# 正式服务必须使用 required；开发服务器默认 disabled。
API_AUTH_MODE=disabled
API_AUTH_BEARER_TOKENS={"replace-with-at-least-32-random-characters":{"id":"admin-user","roles":["admin"]}}
API_AUTH_API_KEYS={}
API_CAPABILITY_SECRET=replace-with-an-independent-32-byte-random-secret
API_CAPABILITY_TTL_SECONDS=600
API_CAPABILITY_MAX_TTL_SECONDS=1800
API_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:8080
API_HOST=127.0.0.1
PORT=5173
API_TRUST_PROXY=false
API_HSTS=false

# 直接由 Node 终止 TLS 时同时设置；经 HTTPS 反向代理时留空。
TLS_CERT_FILE=
TLS_KEY_FILE=

API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_READ=300
API_RATE_LIMIT_WRITE=120
API_RATE_LIMIT_AI=30
API_RATE_LIMIT_UPLOAD=20
API_REQUEST_TIMEOUT_MS=600000
API_HEADERS_TIMEOUT_MS=15000

OFFICE_DOCUMENT_TTL_MS=86400000
OFFICE_MAX_DOCUMENTS=200
OFFICE_ACCESS_TOKEN_TTL_SECONDS=1800
OFFICE_CONFIG_TOKEN_TTL_SECONDS=600
SOLUTION_IMAGE_TTL_MS=86400000
SOLUTION_IMAGE_MAX_ITEMS=200
